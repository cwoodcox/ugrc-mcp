{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "ugrc-mcp",
  "main": "src/index.ts",
  "compatibility_date": "2025-05-01",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true
  },
  "durable_objects": {
    "bindings": [
      { "name": "MCP_OBJECT", "class_name": "UgrcMcp" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_sqlite_classes": ["UgrcMcp"] }
  ]
}
